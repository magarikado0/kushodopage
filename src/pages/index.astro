---
import Base from '~/layouts/Base.astro';
import Hero from '~/components/Hero.astro';
import Section from '~/components/Section.astro';
import NewsList from '~/components/NewsList.astro';
import ExhibitionList from '~/components/ExhibitionList.astro';
import { getExhibitions, getNews } from '~/libs/microcms';

const news = await getNews(5);
const exhibitions = await getExhibitions(3);
---

<Base current="/">
  <Hero />
  <div class="home-accent" aria-hidden="true">
    <span></span>
  </div>

  <Section title="お知らせ" moreHref="/news">
    <NewsList items={news} showDescription />
  </Section>

  <Section title="書展" moreHref="/activities" flush>
    <ExhibitionList exhibitions={exhibitions} />
  </Section>
</Base>

<style>
  .home-accent {
    width: calc(100% - var(--gutter) - var(--gutter));
    max-width: var(--content-width);
    margin: 0 auto;
    height: 12px;
    background: var(--color-primary);
    display: flex;
    justify-content: flex-end;
  }

  .home-accent span {
    width: clamp(56px, 9vw, 120px);
    background: var(--color-black);
  }

  @media (max-width: 760px) {
    .home-accent {
      height: 7px;
    }
  }
</style>
