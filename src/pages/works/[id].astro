---
import type { GetStaticPaths } from 'astro';
import Base from '~/layouts/Base.astro';
import { getWorks } from '~/libs/microcms';

export const getStaticPaths = (async () => {
  const works = await getWorks(100);
  return works.map((w) => ({ params: { id: w.id }, props: { work: w } }));
}) satisfies GetStaticPaths;

const { work } = Astro.props;
---

<Base title={work.title} description={work.caption ?? `${work.title}（${work.style}）`} current="/works">
  <article class="work">
    <div class="container work-head">
      <a class="work-back" href="/works">← 作品一覧</a>
      <div class="work-meta">
        <span class="tag">{work.style}</span>
        {work.exhibition ? <span class="exhibition">{work.exhibition}</span> : null}
      </div>
      <h1 class="work-title">{work.title}</h1>
      {work.author ? <p class="work-author">筆者：{work.author}</p> : null}
    </div>

    <div class="container work-grid">
      <figure class="work-figure">
        {
          work.image?.url ? (
            <img src={work.image.url} alt={work.image.alt ?? work.title} />
          ) : (
            <div class="work-placeholder">{work.title}</div>
          )
        }
      </figure>
      <div class="work-side">
        {work.caption ? (
          <>
            <h2 class="work-h2">作品ノート</h2>
            <p>{work.caption}</p>
          </>
        ) : (
          <p class="work-empty">この作品の説明はありません。</p>
        )}
      </div>
    </div>
  </article>
</Base>

<style>
  .work {
    padding: 2.5rem 0 4rem;
  }

  .work-back {
    display: inline-block;
    font-size: 11px;
    color: var(--color-primary);
    font-family: var(--font-sans);
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .work-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 0.8rem;
  }

  .tag {
    font-size: 10px;
    color: #fff;
    background: var(--color-primary);
    padding: 1px 7px;
    font-family: var(--font-sans);
    letter-spacing: 0.08em;
  }

  .exhibition {
    font-size: 11px;
    color: var(--color-muted);
    font-family: var(--font-sans);
    letter-spacing: 0.05em;
  }

  .work-title {
    font-size: 26px;
    font-weight: 400;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .work-author {
    font-size: 12px;
    color: var(--color-muted);
    font-family: var(--font-sans);
  }

  .work-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .work-figure {
    margin: 0;
    background: var(--color-work);
  }

  .work-figure img {
    width: 100%;
    display: block;
  }

  .work-placeholder {
    aspect-ratio: 3 / 4;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-work-ink);
    font-size: 48px;
    writing-mode: vertical-rl;
    font-family: var(--font-serif);
  }

  .work-h2 {
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.15em;
    color: #fff;
    background: var(--color-primary);
    padding: 0.25rem 0.75rem;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .work-side p {
    font-size: 13px;
    font-family: var(--font-sans);
    font-weight: 300;
    line-height: 2;
    color: var(--color-subtext);
  }

  .work-empty {
    color: var(--color-faint);
    font-family: var(--font-sans);
    font-size: 12px;
  }

  @media (max-width: 760px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
