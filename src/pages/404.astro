---
import Base from '~/layouts/Base.astro';
---

<Base title="ページが見つかりません" description="404 Not Found">
  <section class="not-found">
    <div class="container">
      <div class="nf-label">404</div>
      <h1 class="nf-title">お探しのページが見つかりませんでした</h1>
      <p class="nf-body">
        URLが間違っているか、ページが移動・削除されている可能性があります。
      </p>
      <div class="nf-actions">
        <a class="nf-link" href="/">トップページに戻る</a>
        <a class="nf-link is-ghost" href="/news">お知らせを見る</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .not-found {
    padding: 5rem var(--gutter);
    text-align: center;
  }

  .nf-label {
    font-size: 80px;
    font-weight: 300;
    color: var(--color-primary);
    letter-spacing: 0.1em;
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .nf-title {
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }

  .nf-body {
    font-size: 13px;
    font-family: var(--font-sans);
    font-weight: 300;
    color: var(--color-muted);
    margin-bottom: 2.5rem;
  }

  .nf-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .nf-link {
    font-size: 11px;
    color: #fff;
    background: var(--color-black);
    font-family: var(--font-sans);
    letter-spacing: 0.15em;
    padding: 0.6rem 1.4rem;
  }

  .nf-link.is-ghost {
    background: transparent;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
  }

  .nf-link:hover {
    opacity: 0.8;
  }
</style>
