---
import Base from '~/layouts/Base.astro';
import Section from '~/components/Section.astro';
import WorksGrid from '~/components/WorksGrid.astro';
import { getExhibitions, getWorks } from '~/libs/microcms';
import { formatDateRange } from '~/libs/format';

const works = await getWorks(30);
const exhibitions = await getExhibitions(20);
---

<Base
  title="作品・書展"
  description="京都大学書道部の作品とこれまでの書展一覧。漢字・かな・篆刻の作品アーカイブ。"
  current="/works"
>
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-label">Works & Exhibitions</div>
      <h1 class="page-hero-title">作品・書展</h1>
      <p class="page-hero-sub">
        部員による作品アーカイブと、これまでに開催した書展の記録です。
      </p>
    </div>
  </section>

  <Section title="作品アーカイブ">
    {
      works.length === 0 ? (
        <p class="empty">作品はまだありません。</p>
      ) : (
        <WorksGrid works={works} columns={3} />
      )
    }
  </Section>

  <Section title="書展一覧" flush>
    <ul class="ex-list">
      {
        exhibitions.length === 0 ? (
          <li class="empty">書展情報はまだありません。</li>
        ) : (
          exhibitions.map((ex) => (
            <li class="ex-item">
              <div class="ex-meta">
                <div class="ex-year">{ex.year}</div>
                <div class="ex-venue">
                  {ex.venue}
                  {ex.address ? <span>　{ex.address}</span> : null}
                </div>
              </div>
              <div class="ex-body">
                <a class="ex-ttl" href={`/exhibitions/${ex.id}`}>{ex.title}</a>
                <div class="ex-date">
                  {formatDateRange(ex.startDate, ex.endDate)}
                </div>
                <p class="ex-desc">{ex.description}</p>
              </div>
              <a class="ex-arrow" href={`/exhibitions/${ex.id}`}>詳細 →</a>
            </li>
          ))
        )
      }
    </ul>
  </Section>
</Base>

<style>
  .page-hero {
    padding: 3rem var(--gutter) 1.5rem;
    border-bottom: 1px solid var(--color-line);
  }

  .page-hero-label {
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-weight: 300;
    margin-bottom: 0.8rem;
  }

  .page-hero-title {
    font-size: 26px;
    font-weight: 400;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .page-hero-sub {
    font-size: 12px;
    font-family: var(--font-sans);
    font-weight: 300;
    color: var(--color-subtext);
    line-height: 1.8;
  }

  .empty {
    padding: 2rem 0;
    color: var(--color-faint);
    font-family: var(--font-sans);
    font-size: 12px;
    text-align: center;
  }

  .ex-list {
    list-style: none;
  }

  .ex-item {
    display: grid;
    grid-template-columns: 9rem 1fr auto;
    gap: 1.5rem;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--color-line-soft);
    align-items: start;
  }

  .ex-item:first-child {
    border-top: 1px solid var(--color-line-soft);
  }

  .ex-year {
    font-size: 20px;
    font-weight: 300;
    color: var(--color-primary);
    font-family: var(--font-serif);
    letter-spacing: 0.05em;
  }

  .ex-venue {
    font-size: 11px;
    font-family: var(--font-sans);
    font-weight: 300;
    color: var(--color-faint);
    margin-top: 0.3rem;
    letter-spacing: 0.05em;
  }

  .ex-ttl {
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--color-ink);
    transition: color 0.2s ease;
  }

  .ex-ttl:hover {
    color: var(--color-primary);
  }

  .ex-date {
    font-size: 11px;
    font-family: var(--font-sans);
    font-weight: 300;
    color: var(--color-muted);
    margin: 0.4rem 0 0.6rem;
    letter-spacing: 0.04em;
  }

  .ex-desc {
    font-size: 12px;
    font-family: var(--font-sans);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-subtext);
    letter-spacing: 0.04em;
  }

  .ex-arrow {
    font-size: 11px;
    font-family: var(--font-sans);
    color: var(--color-primary);
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .ex-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
