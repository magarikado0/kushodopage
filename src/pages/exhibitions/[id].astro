---
import type { GetStaticPaths } from 'astro';
import Base from '~/layouts/Base.astro';
import { getAllExhibitionIds, getExhibitionById } from '~/libs/microcms';
import { formatDateRange, excerpt } from '~/libs/format';

export const getStaticPaths = (async () => {
  const ids = await getAllExhibitionIds();
  return ids.map((id) => ({ params: { id } }));
}) satisfies GetStaticPaths;

const { id } = Astro.params;
const exhibition = id ? await getExhibitionById(id) : null;

if (!exhibition) {
  return Astro.redirect('/activities');
}
---

<Base
  title={exhibition.title}
  description={excerpt(exhibition.description, 120)}
  current="/activities"
>
  <article class="ex">
    <div class="container ex-head">
      <a class="ex-back" href="/activities">← 活動記録</a>
      <div class="ex-label">書展アーカイブ</div>
      <h1 class="ex-title">{exhibition.title}</h1>
      <dl class="ex-info">
        <div>
          <dt>会期</dt>
          <dd>{formatDateRange(exhibition.startDate, exhibition.endDate)}</dd>
        </div>
        <div>
          <dt>会場</dt>
          <dd>
            {exhibition.venue}
            {exhibition.address ? `（${exhibition.address}）` : ''}
          </dd>
        </div>
      </dl>
    </div>

    {
      exhibition.heroImage?.url && (
        <div class="ex-hero">
          <img
            src={exhibition.heroImage.url}
            alt={exhibition.heroImage.alt ?? exhibition.title}
          />
        </div>
      )
    }

    <div class="container">
      <div class="ex-body">
        <h2 class="ex-h2">書展について</h2>
        <p>{exhibition.description}</p>
      </div>

      {
        (exhibition.brochureUrl || exhibition.artoirUrl) && (
          <div class="ex-links">
            <h2 class="ex-h2">作品と記録</h2>
            <div class="ex-link-list">
              {exhibition.artoirUrl && (
                <a href={exhibition.artoirUrl} target="_blank" rel="noreferrer">
                  <span>展示作品</span>
                  <strong>Artoirで作品を見る ↗</strong>
                </a>
              )}
              {exhibition.brochureUrl && (
                <a href={exhibition.brochureUrl} target="_blank" rel="noreferrer">
                  <span>書展資料</span>
                  <strong>パンフレットを見る ↗</strong>
                </a>
              )}
            </div>
          </div>
        )
      }
    </div>
  </article>
</Base>

<style>
  .ex {
    padding-bottom: 4rem;
  }

  .ex-head {
    padding-top: 2.5rem;
  }

  .ex-back {
    display: inline-block;
    font-size: 14px;
    color: var(--color-primary);
    font-family: var(--font-sans);
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .ex-label {
    font-size: 13px;
    letter-spacing: 0.25em;
    color: var(--color-primary);
    font-family: var(--font-sans);
    margin-bottom: 0.6rem;
  }

  .ex-title {
    font-size: 34px;
    font-weight: 400;
    letter-spacing: 0.05em;
    margin-bottom: 1.2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--color-primary);
  }

  .ex-info {
    font-family: var(--font-sans);
  }

  .ex-info div {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 1rem;
    padding: 0.5rem 0;
  }

  .ex-info dt {
    font-size: 13px;
    color: var(--color-primary);
    letter-spacing: 0.15em;
    font-weight: 400;
  }

  .ex-info dd {
    font-size: 16px;
    color: var(--color-ink);
    font-weight: 400;
  }

  .ex-hero {
    margin: 2rem 0;
  }

  .ex-hero img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border: 1px solid var(--color-line);
  }

  .ex-body {
    margin-top: 2rem;
  }

  .ex-h2 {
    font-size: 19px;
    font-weight: 400;
    letter-spacing: 0.15em;
    color: #fff;
    background: var(--color-black);
    padding: 0.25rem 0.75rem;
    display: inline-block;
    margin-bottom: 1.2rem;
  }

  .ex-body p {
    font-size: 15px;
    font-family: var(--font-sans);
    font-weight: 400;
    line-height: 2;
    color: var(--color-ink);
    letter-spacing: 0.04em;
  }

  .ex-links {
    margin-top: 3rem;
  }

  .ex-link-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .ex-link-list a {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.2rem;
    border: 1px solid var(--color-line);
    background: #fff;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .ex-link-list a:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .ex-link-list span {
    font-size: 12px;
    color: var(--color-faint);
    font-family: var(--font-sans);
    letter-spacing: 0.15em;
  }

  .ex-link-list strong {
    font-size: 16px;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-weight: 400;
    letter-spacing: 0.06em;
  }

  @media (max-width: 600px) {
    .ex-link-list {
      grid-template-columns: 1fr;
    }
  }
</style>
