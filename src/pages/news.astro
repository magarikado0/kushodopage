---
import Base from '~/layouts/Base.astro';
import Section from '~/components/Section.astro';
import NewsList from '~/components/NewsList.astro';
import { getNews } from '~/libs/microcms';

const news = await getNews(200);
---

<Base
  title="お知らせ"
  description="京都大学書道部からのお知らせ。書展や活動、入部関連の最新情報。"
  current="/news"
>
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-label">News</div>
      <h1 class="page-hero-title">お知らせ</h1>
      <p class="page-hero-sub">書展や活動、入部関連の最新情報をお届けします。</p>
    </div>
  </section>

  <Section title="お知らせ一覧" flush>
    <NewsList items={news} />
  </Section>
</Base>

<style>
  .page-hero {
    padding: 3rem var(--gutter) 1.5rem;
    border-bottom: 1px solid var(--color-line);
  }

  .page-hero-label {
    font-size: 13px;
    letter-spacing: 0.25em;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-weight: 400;
    margin-bottom: 0.8rem;
  }

  .page-hero-title {
    font-size: 31px;
    font-weight: 400;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .page-hero-sub {
    font-size: 15px;
    font-family: var(--font-sans);
    font-weight: 400;
    color: var(--color-subtext);
    line-height: 1.8;
  }
</style>
