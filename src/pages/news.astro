---
import Base from '~/layouts/Base.astro';
import Section from '~/components/Section.astro';
import NewsList from '~/components/NewsList.astro';
import { getNews } from '~/libs/microcms';

const news = await getNews(100);
const byYear = new Map<number, typeof news>();

for (const item of news) {
  const year = new Date(item.publishedAt).getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(item);
}

const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Base
  title="お知らせ"
  description="京都大学書道部からのお知らせ。書展や活動、入部関連の最新情報。"
  current="/news"
>
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-label">News</div>
      <h1 class="page-hero-title">お知らせ</h1>
      <p class="page-hero-sub">書展や活動、入部関連の最新情報をお届けします。</p>
    </div>
  </section>

  {
    years.length === 0 ? (
      <Section title="お知らせ" flush>
        <p class="empty">お知らせはまだありません。</p>
      </Section>
    ) : (
      years.map((year, i) => (
        <Section title={`${year}年`} flush={i === years.length - 1}>
          <NewsList items={byYear.get(year)!} />
        </Section>
      ))
    )
  }
</Base>

<style>
  .page-hero {
    padding: 3rem var(--gutter) 1.5rem;
    border-bottom: 1px solid var(--color-line);
  }

  .page-hero-label {
    font-size: 11px;
    letter-spacing: 0.25em;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-weight: 400;
    margin-bottom: 0.8rem;
  }

  .page-hero-title {
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .page-hero-sub {
    font-size: 13px;
    font-family: var(--font-sans);
    font-weight: 400;
    color: var(--color-subtext);
    line-height: 1.8;
  }

  .empty {
    padding: 2rem 0;
    color: var(--color-faint);
    font-family: var(--font-sans);
    font-size: 13px;
    text-align: center;
  }
</style>
