---
import { NAV_ITEMS, SITE } from '~/libs/site';

interface Props {
  current?: string;
}

const { current } = Astro.props;
---

<header class="nav">
  <a class="nav-logo" href="/" aria-label={`${SITE.name} トップページ`}>
    <img src="/header.png" alt={SITE.name} />
  </a>
  <button
    class="nav-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="global-navigation"
    aria-label="メニューを開く"
  >
    <span class="nav-toggle-line"></span>
    <span class="nav-toggle-line"></span>
    <span class="nav-toggle-line"></span>
  </button>
  <ul class="nav-links" id="global-navigation">
    {
      NAV_ITEMS.map((item) => (
        <li class={current === item.href ? 'is-active' : ''}>
          <a href={item.href}>{item.label}</a>
        </li>
      ))
    }
  </ul>
</header>

<style>
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.4rem 2.5rem;
    background: #fff;
    border-top: 3px solid var(--color-black);
    border-right: 1px solid var(--color-line);
    border-bottom: 2px solid var(--color-primary);
    border-left: 3px solid var(--color-black);
    border-radius: 7px;
    width: calc(100% - var(--gutter) - var(--gutter));
    max-width: var(--content-width);
    margin: 0.75rem auto;
    gap: 1.5rem;
    position: relative;
    z-index: 30;
    box-shadow: 0 5px 16px rgba(26, 20, 14, 0.06);
  }

  .nav-logo {
    display: block;
    flex: 0 1 230px;
  }

  .nav-logo img {
    display: block;
    width: 100%;
    height: auto;
  }

  .nav-toggle {
    display: none;
  }

  .nav-links {
    display: flex;
    gap: 1.1rem;
    list-style: none;
    font-size: 15px;
    letter-spacing: 0.1em;
    font-family: var(--font-sans);
    font-weight: 400;
    color: var(--color-text);
  }

  .nav-links a {
    display: inline-block;
    padding: 0.35rem 0.55rem;
    border-radius: 4px;
    transition:
      color 0.2s ease,
      background 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--color-primary);
    background: rgba(155, 35, 53, 0.06);
  }

  .nav-links li.is-active a {
    color: var(--color-primary);
    background: rgba(155, 35, 53, 0.08);
  }

  .nav-links li:last-child {
    color: var(--color-black);
    border: 1px solid var(--color-black);
    border-radius: 3px;
    padding: 0;
    box-shadow: 0 1px 4px rgba(26, 20, 14, 0.04);
  }

  .nav-links li:last-child a {
    padding: 0.45rem 0.9rem;
  }

  .nav-links li:last-child a:hover {
    background: var(--color-black);
    color: #fff;
  }

  @media (max-width: 760px) {
    .nav {
      padding: 1rem 1.2rem;
      margin: 0.5rem auto;
      position: relative;
      gap: 1rem;
    }

    .nav-logo {
      flex-basis: 190px;
    }

    .nav-toggle {
      display: grid;
      place-content: center;
      gap: 5px;
      width: 44px;
      height: 44px;
      margin-left: auto;
      color: var(--color-black);
      border: 1px solid var(--color-black);
      border-radius: 4px;
      background: #fbfaf7;
      box-shadow: 0 1px 4px rgba(26, 20, 14, 0.04);
    }

    .nav-toggle-line {
      display: block;
      width: 20px;
      height: 1px;
      background: currentColor;
      transition:
        transform 0.2s ease,
        opacity 0.2s ease;
    }

    .nav-toggle[aria-expanded='true'] .nav-toggle-line:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }

    .nav-toggle[aria-expanded='true'] .nav-toggle-line:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle[aria-expanded='true'] .nav-toggle-line:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }

    .nav-links {
      display: none;
      position: absolute;
      z-index: 20;
      top: calc(100% + 7px);
      right: 0;
      left: 0;
      flex-direction: column;
      gap: 0;
      padding: 0.75rem 1.2rem 1rem;
      background: #fff;
      border-top: 1px solid var(--color-line);
      border-right: 1px solid var(--color-line);
      border-bottom: 2px solid var(--color-primary);
      border-left: 3px solid var(--color-black);
      border-radius: 6px;
      font-size: 14px;
      box-shadow: 0 8px 18px rgba(10, 10, 10, 0.07);
    }

    .nav-links.is-open {
      display: flex;
    }

    .nav-links li {
      border-bottom: 1px solid var(--color-line-soft);
    }

    .nav-links li a {
      display: block;
      padding: 0.85rem 0.2rem;
    }

    .nav-links li:last-child {
      margin-top: 0.7rem;
      padding: 0;
      text-align: center;
      border: 1px solid var(--color-black);
    }

    .nav-links li:last-child a {
      padding: 0.65rem 0.9rem;
    }
  }
</style>

<script>
  const nav = document.querySelector<HTMLElement>('.nav');
  const toggle = nav?.querySelector<HTMLButtonElement>('.nav-toggle');
  const links = nav?.querySelector<HTMLElement>('.nav-links');

  const closeMenu = () => {
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'メニューを開く');
    links?.classList.remove('is-open');
  };

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'メニューを開く' : 'メニューを閉じる');
    links?.classList.toggle('is-open', !isOpen);
  });

  links?.addEventListener('click', (event) => {
    if ((event.target as HTMLElement).closest('a')) closeMenu();
  });

  document.addEventListener('click', (event) => {
    if (nav && !nav.contains(event.target as Node)) closeMenu();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeMenu();
      toggle?.focus();
    }
  });

  window.matchMedia('(min-width: 761px)').addEventListener('change', closeMenu);
</script>
