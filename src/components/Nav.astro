---
import { NAV_ITEMS, SITE } from '~/libs/site';

interface Props {
  current?: string;
}

const { current } = Astro.props;
---

<header class="nav">
  <a class="nav-logo" href="/">
    {SITE.name}
    <span>{SITE.nameEn}</span>
  </a>
  <ul class="nav-links">
    {
      NAV_ITEMS.map((item) => (
        <li class={current === item.href ? 'is-active' : ''}>
          <a href={item.href}>{item.label}</a>
        </li>
      ))
    }
  </ul>
</header>

<style>
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.4rem 2.5rem;
    background: #fff;
    border-top: 4px solid var(--color-black);
    border-bottom: 3px solid var(--color-primary);
    border-left: 6px solid var(--color-black);
    gap: 1.5rem;
  }

  .nav-logo {
    font-size: 15px;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--color-ink);
    line-height: 1.2;
  }

  .nav-logo span {
    font-size: 10px;
    color: var(--color-primary);
    display: block;
    letter-spacing: 0.08em;
    font-family: var(--font-sans);
    font-weight: 300;
    margin-top: 2px;
  }

  .nav-links {
    display: flex;
    gap: 2.2rem;
    list-style: none;
    font-size: 12px;
    letter-spacing: 0.1em;
    font-family: var(--font-sans);
    font-weight: 300;
    color: var(--color-text);
  }

  .nav-links a {
    display: inline-block;
    padding: 0.2rem 0;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--color-primary);
  }

  .nav-links li.is-active a {
    color: var(--color-primary);
  }

  .nav-links li:last-child {
    color: var(--color-black);
    border: 1px solid var(--color-black);
    padding: 0.3rem 0.9rem;
  }

  .nav-links li:last-child a:hover {
    background: var(--color-black);
    color: #fff;
  }

  @media (max-width: 760px) {
    .nav {
      padding: 1rem 1.2rem;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .nav-links {
      gap: 1rem;
      font-size: 11px;
      flex-wrap: wrap;
    }
  }
</style>
