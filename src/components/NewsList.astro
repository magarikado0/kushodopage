---
import type { NewsItem } from '~/types/content';
import { excerpt, formatDate } from '~/libs/format';

interface Props {
  items: NewsItem[];
  /** 末尾の区切り線を表示しない（ページ末尾用） */
  flush?: boolean;
  /** トップページ向けに本文の抜粋を表示する */
  showDescription?: boolean;
}

const { items, flush = false, showDescription = false } = Astro.props;
---

<div class="news-list">
  {
    items.length === 0 ? (
      <p class="news-empty">お知らせはまだありません。</p>
    ) : (
      items.map((item) => (
        <a class:list={['news-item', { 'is-rich': showDescription }]} href={`/news/${item.id}`}>
          <span class="news-date">{formatDate(item.publishedAt)}</span>
          <span class="news-tag">
            {Array.isArray(item.category) ? item.category.join('・') : item.category}
          </span>
          {
            showDescription ? (
              <span class="news-copy">
                <span class="news-ttl">{item.title}</span>
                <span class="news-description">
                  {item.description?.trim() || excerpt(item.content, 96)}
                </span>
              </span>
            ) : (
              <span class="news-ttl">{item.title}</span>
            )
          }
        </a>
      ))
    )
  }
</div>

<style>
  .news-list {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #fff;
    border: 1px solid var(--color-line-soft);
    border-radius: 6px;
    box-shadow: var(--shadow-paper);
  }

  .news-item {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid var(--color-line-soft);
    transition: background 0.2s ease;
  }

  .news-item:first-child {
    border-top: 0;
  }

  .news-item:last-child {
    border-bottom: 0;
  }

  .news-item:hover {
    background: rgba(155, 35, 53, 0.04);
  }

  .news-item.is-rich {
    align-items: start;
    gap: 1.25rem;
    padding: 1.15rem 1.25rem;
  }

  .news-date {
    font-size: 14px;
    color: var(--color-faint);
    font-family: var(--font-sans);
    font-weight: 400;
    white-space: nowrap;
    min-width: 76px;
  }

  .news-tag {
    font-size: 13px;
    color: #fff;
    background: var(--color-primary);
    padding: 1px 7px;
    letter-spacing: 0.08em;
    font-family: var(--font-sans);
    font-weight: 400;
    white-space: nowrap;
  }

  .news-ttl {
    display: block;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    line-height: 1.5;
    font-family: var(--font-sans);
  }

  .news-copy {
    display: block;
    min-width: 0;
  }

  .news-description {
    display: -webkit-box;
    margin-top: 0.35rem;
    overflow: hidden;
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    line-height: 1.75;
    letter-spacing: 0.035em;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .news-empty {
    padding: 2rem 0;
    color: var(--color-faint);
    font-family: var(--font-sans);
    font-size: 15px;
    text-align: center;
  }

  @media (max-width: 600px) {
    .news-item {
      flex-wrap: wrap;
      gap: 0.35rem 0.8rem;
      padding: 0.7rem 0.9rem;
    }
    .news-item.is-rich {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.4rem 0.75rem;
      padding: 0.95rem;
    }
    .news-date {
      font-size: 11px;
      min-width: 70px;
    }
    .news-tag {
      font-size: 10px;
      padding: 1px 6px;
    }
    .news-ttl {
      width: 100%;
      font-size: 13px;
      line-height: 1.45;
    }
    .is-rich .news-copy {
      grid-column: 1 / -1;
      margin-top: 0.15rem;
    }
    .is-rich .news-ttl {
      font-size: 14px;
      line-height: 1.55;
    }
    .news-description {
      margin-top: 0.3rem;
      font-size: 12px;
      line-height: 1.65;
      -webkit-line-clamp: 3;
    }
  }
</style>
