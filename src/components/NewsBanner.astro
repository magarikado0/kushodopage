---
import type { NewsItem } from '~/types/content';
import { formatDate } from '~/libs/format';

interface Props {
  item: NewsItem;
}

const { item } = Astro.props;
---

<a class="news-banner" href={`/news/${item.id}`}>
  <span class="news-banner-label">NEW</span>
  <span class="news-banner-text">{item.title}</span>
  <span class="news-banner-date">{formatDate(item.publishedAt)}</span>
</a>

<style>
  .news-banner {
    background: var(--color-primary);
    padding: 0.7rem var(--gutter);
    display: flex;
    align-items: center;
    gap: 1.5rem;
    transition: opacity 0.2s ease;
  }

  .news-banner:hover {
    opacity: 0.9;
  }

  .news-banner-label {
    font-size: 10px;
    letter-spacing: 0.25em;
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 300;
    white-space: nowrap;
    opacity: 0.8;
  }

  .news-banner-text {
    font-size: 12px;
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 300;
    letter-spacing: 0.08em;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .news-banner-date {
    font-size: 10px;
    color: var(--color-primary-tint);
    font-family: var(--font-sans);
    font-weight: 300;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .news-banner {
      flex-wrap: wrap;
      padding: 0.7rem 1.2rem;
      gap: 0.5rem 1rem;
    }
    .news-banner-text {
      white-space: normal;
      order: 3;
      flex-basis: 100%;
    }
  }
</style>
