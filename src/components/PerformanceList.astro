---
import type { Performance } from '~/types/content';

interface Props {
  performances: Performance[];
}

const { performances } = Astro.props;
const groups = [
  {
    title: 'NF書道パフォーマンス',
    performances: performances.filter((performance) => {
      const types = Array.isArray(performance.type)
        ? performance.type
        : [performance.type];
      return types.includes('NF書道パフォーマンス');
    }),
  },
  {
    title: '新歓書道パフォーマンス',
    performances: performances.filter((performance) => {
      const types = Array.isArray(performance.type)
        ? performance.type
        : [performance.type];
      return types.includes('新歓書道パフォーマンス');
    }),
  },
] as const;
---

<div class="performance-groups">
  {
    performances.length === 0 ? (
      <p class="empty">書道パフォーマンスの記録は順次掲載します。</p>
    ) : (
      groups.map((group) => (
        <section class="performance-group">
          <h3 class="performance-heading">{group.title}</h3>
          {group.performances.length === 0 ? (
            <p class="empty performance-empty">記録は順次掲載します。</p>
          ) : (
            <div class="performance-list">
              {group.performances.map((performance) => (
                <a
                  class="performance-item"
                  href={performance.url}
                  target="_blank"
                  rel="noreferrer"
                >
                  <span class="performance-year">{performance.year}</span>
                  <span class="performance-link" aria-hidden="true">↗</span>
                </a>
              ))}
            </div>
          )}
        </section>
      ))
    )
  }
</div>

<style>
  .performance-groups {
    display: grid;
    gap: 2.5rem;
  }

  .performance-heading {
    margin-bottom: 0.85rem;
    padding-left: 0.75rem;
    border-left: 2px solid var(--color-primary);
    color: var(--color-ink);
    font-size: 19px;
    font-weight: 400;
    letter-spacing: 0.08em;
  }

  .performance-list {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
  }

  .performance-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.1rem;
    color: var(--color-primary);
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .performance-item::before {
    content: '・';
    color: var(--color-primary);
  }

  .performance-item:hover {
    color: var(--color-ink);
    transform: translateX(0.2rem);
  }

  .performance-year {
    font-family: var(--font-serif);
    font-size: 18px;
    letter-spacing: 0.08em;
  }

  .performance-link {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1;
  }

  .empty {
    padding: 2rem 1rem;
    color: var(--color-faint);
    font-family: var(--font-sans);
    font-size: 14px;
    text-align: center;
  }

  .performance-empty {
    border-top: 1px solid var(--color-line-soft);
    border-bottom: 1px solid var(--color-line-soft);
  }

  @media (max-width: 600px) {
    .performance-year {
      font-size: 16px;
    }

    .performance-link {
      font-size: 12px;
    }
  }
</style>
