---
import { SITE } from '~/libs/site';
import { formatDateRange } from '~/libs/format';
import { getFeaturedExhibition } from '~/libs/microcms';

const exhibition = await getFeaturedExhibition();
---

<section class="hero">
  <div class="hero-left">
    <div>
      <h1 class="hero-title">{SITE.name}</h1>
    </div>
    <div class="hero-bottom">
      {
        exhibition ? (
          <>
            <div class="ex-label">次回の書展</div>
            <a class="ex-title" href={`/exhibitions/${exhibition.id}`}>
              {exhibition.title}
            </a>
            <div class="ex-meta">
              {formatDateRange(exhibition.startDate, exhibition.endDate)}
              <br />
              {exhibition.venue}
              {exhibition.address ? `　${exhibition.address}` : ''}
            </div>
            <a class="ex-link" href={`/exhibitions/${exhibition.id}`}>詳細を見る →</a>
          </>
        ) : (
          <>
            <div class="ex-label">次回の書展</div>
            <div class="ex-title">未定</div>
            <div class="ex-meta">次回の書展は現在調整中です。</div>
          </>
        )
      }
    </div>
  </div>
  <div class="hero-right">
    <img
      class="hero-image"
      src="/H30_shoka_header.jpg"
      alt="書展会場に展示された書作品"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: calc(100% - var(--gutter) - var(--gutter));
    max-width: var(--content-width);
    margin: 0 auto;
    border-bottom: 1px solid var(--color-line);
    min-height: 330px;
    position: relative;
    z-index: 1;
    box-shadow: var(--shadow-paper);
  }

  .hero-left {
    padding: 2.5rem var(--gutter);
    background: #fff;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-right: 1px solid var(--color-line);
  }

  .hero-title {
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 0.08em;
    line-height: 1.6;
    margin-bottom: 0;
    color: var(--color-ink);
  }

  .hero-bottom {
    margin-top: 2rem;
    padding-left: 1.4rem;
    border-left: 3px solid var(--color-primary);
  }

  .ex-label {
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-weight: 400;
    margin-bottom: 0.65rem;
  }

  .ex-title {
    display: block;
    font-size: 20px;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--color-ink);
    line-height: 1.5;
    margin-bottom: 0.55rem;
    transition: color 0.2s ease;
  }

  .ex-title:hover {
    color: var(--color-primary);
  }

  .ex-meta {
    font-size: 14px;
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-weight: 400;
    line-height: 1.9;
    letter-spacing: 0.05em;
  }

  .ex-link {
    margin-top: 1rem;
    font-size: 13px;
    color: #fff;
    background: var(--color-black);
    font-family: var(--font-sans);
    font-weight: 400;
    letter-spacing: 0.15em;
    display: inline-block;
    padding: 0.55rem 1.2rem;
    border-radius: 3px;
    box-shadow: 0 2px 6px rgba(10, 10, 10, 0.08);
    transition: opacity 0.2s ease;
  }

  .ex-link:hover {
    opacity: 0.85;
  }

  .hero-right {
    overflow: hidden;
    background: #ddd6cb;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    min-height: 330px;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-left {
      border-right: 0;
      border-bottom: 1px solid var(--color-line);
      padding: 2.5rem 1.2rem;
    }
    .hero-bottom {
      padding-left: 1rem;
    }
    .hero-right {
      min-height: 220px;
    }
  }
</style>
