---
import { SITE } from '~/libs/site';
import { formatDateRange } from '~/libs/format';
import { getFeaturedExhibition } from '~/libs/microcms';

const exhibition = await getFeaturedExhibition();
---

<section class="hero">
  <div class="hero-left">
    <div class="hero-bottom">
      {
        exhibition ? (
          <>
            <div class="ex-label">次回の書展</div>
            <a class="ex-title" href={`/exhibitions/${exhibition.id}`}>
              {exhibition.title}
            </a>
            <div class="ex-meta">
              <span class="ex-date">{formatDateRange(exhibition.startDate, exhibition.endDate)}</span>
              <br />
              {exhibition.venue}
              {exhibition.address ? `　${exhibition.address}` : ''}
            </div>
            <a class="ex-link" href={`/exhibitions/${exhibition.id}`}>詳細を見る →</a>
          </>
        ) : (
          <>
            <div class="ex-label">次回の書展</div>
            <div class="ex-title">未定</div>
            <div class="ex-meta">次回の書展は現在調整中です。</div>
          </>
        )
      }
    </div>
  </div>
  <div class="hero-right">
    <img
      class="hero-image"
      src="/H30_shoka_header.jpg"
      alt="書展会場に展示された書作品"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(0, 0.88fr);
    width: calc(100% - var(--gutter) - var(--gutter));
    max-width: var(--content-width);
    margin: 0 auto;
    border-radius: 0 0 7px 7px;
    overflow: hidden;
    border-bottom: 1px solid var(--color-line);
    min-height: 330px;
    position: relative;
    z-index: 1;
    box-shadow: var(--shadow-paper);
  }

  .hero-left {
    padding: 2.5rem var(--gutter);
    background:
      linear-gradient(135deg, rgba(245, 239, 229, 0.65), rgba(255, 255, 255, 0) 42%),
      #fff;
    display: flex;
    align-items: center;
    border-right: 1px solid var(--color-line);
    position: relative;
  }

  .hero-left::after {
    content: '';
    position: absolute;
    right: 1.4rem;
    bottom: 1.3rem;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(186, 173, 152, 0.16), transparent 70%);
    pointer-events: none;
  }

  .hero-bottom {
    margin-top: 0;
    padding-left: 1.2rem;
    border-left: 2px solid rgba(155, 35, 53, 0.7);
    position: relative;
    max-width: 30rem;
    width: 100%;
  }

  .hero-bottom::before {
    content: '';
    position: absolute;
    left: -0.4rem;
    top: 0.15rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: rgba(155, 35, 53, 0.55);
  }

  .ex-label {
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-weight: 500;
    margin-bottom: 0.7rem;
    opacity: 0.86;
  }

  .ex-title {
    display: block;
    font-size: 21px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    line-height: 1.6;
    margin-bottom: 0.7rem;
    transition: color 0.2s ease;
  }

  .ex-title:hover {
    color: var(--color-primary);
  }

  .ex-meta {
    font-size: 14px;
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-weight: 400;
    line-height: 1.95;
    letter-spacing: 0.02em;
  }

  .ex-date {
    display: block;
    white-space: nowrap;
  }

  .ex-link {
    margin-top: 1.15rem;
    font-size: 13px;
    color: #fff;
    background: var(--color-black);
    font-family: var(--font-sans);
    font-weight: 400;
    letter-spacing: 0.08em;
    display: inline-block;
    padding: 0.55rem 1.2rem;
    border-radius: 5px;
    box-shadow: 0 2px 6px rgba(10, 10, 10, 0.08);
    transition: opacity 0.2s ease;
  }

  .ex-link:hover {
    opacity: 0.85;
  }

  .hero-right {
    overflow: hidden;
    background: #ddd6cb;
    position: relative;
  }

  .hero-right::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(26, 20, 14, 0.12), transparent 14%),
      linear-gradient(180deg, rgba(26, 20, 14, 0.06), transparent 12%, transparent 88%, rgba(26, 20, 14, 0.08)),
      linear-gradient(270deg, rgba(26, 20, 14, 0.08), transparent 10%);
    pointer-events: none;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    min-height: 330px;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-left {
      border-right: 0;
      border-bottom: 1px solid var(--color-line);
      padding: 2.5rem 1.2rem;
    }
    .hero-left::after {
      right: 0.6rem;
      bottom: 1rem;
      width: 90px;
      height: 90px;
    }
    .hero-bottom {
      padding-left: 1rem;
    }
    .hero-right {
      min-height: 0;
    }
    .hero-image {
      min-height: 180px;
    }
  }
</style>
