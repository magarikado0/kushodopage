---
import { SITE } from '~/libs/site';
import { formatDateRange } from '~/libs/format';
import { getFeaturedExhibition } from '~/libs/microcms';

const exhibition = await getFeaturedExhibition();
---

<section class="hero">
  <div class="hero-left">
    <div>
      <div class="hero-label">京都大学公認団体　創部 {SITE.founded}年</div>
      <h1 class="hero-title">{SITE.name}</h1>
      <p class="hero-body">
        毎年初夏と冬の2回、建仁寺にて学外書展を開催しています。漢字・かな・篆刻など多様な書体に取り組む部員が、古典の臨書から自由作品まで幅広く活動しています。経験の有無は問いません。
      </p>
    </div>
    <div class="hero-bottom">
      {
        exhibition ? (
          <>
            <div class="ex-label">次回の書展</div>
            <a class="ex-title" href={`/exhibitions/${exhibition.id}`}>
              {exhibition.title}
            </a>
            <div class="ex-meta">
              {formatDateRange(exhibition.startDate, exhibition.endDate)}
              <br />
              {exhibition.venue}
              {exhibition.address ? `　${exhibition.address}` : ''}
            </div>
            <a class="ex-link" href={`/exhibitions/${exhibition.id}`}>詳細を見る →</a>
          </>
        ) : (
          <>
            <div class="ex-label">次回の書展</div>
            <div class="ex-title">未定</div>
            <div class="ex-meta">次回の書展は現在調整中です。</div>
          </>
        )
      }
    </div>
  </div>
  <div class="hero-right">
    <div class="placeholder-frame">
      <div class="placeholder-works">
        <div class="p-scroll" style="width:48px;height:140px"><span class="p-scroll-text">天地</span></div>
        <div class="p-scroll" style="width:48px;height:160px"><span class="p-scroll-text">山川</span></div>
        <div class="p-scroll" style="width:48px;height:130px"><span class="p-scroll-text">風雅</span></div>
      </div>
      <div class="placeholder-floor"></div>
    </div>
    <div class="placeholder-caption">← 書展会場の写真が入ります →</div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--color-line);
    min-height: 380px;
  }

  .hero-left {
    padding: 3.5rem var(--gutter);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-right: 1px solid var(--color-line);
  }

  .hero-label {
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-weight: 300;
    margin-bottom: 1.2rem;
  }

  .hero-title {
    font-size: 26px;
    font-weight: 400;
    letter-spacing: 0.08em;
    line-height: 1.6;
    margin-bottom: 1.4rem;
    color: var(--color-ink);
  }

  .hero-body {
    font-size: 12px;
    font-family: var(--font-sans);
    font-weight: 300;
    line-height: 2.1;
    color: var(--color-subtext);
    letter-spacing: 0.05em;
  }

  .hero-bottom {
    margin-top: 2.5rem;
  }

  .ex-label {
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-weight: 300;
    margin-bottom: 0.5rem;
  }

  .ex-title {
    display: block;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--color-ink);
    margin-bottom: 0.3rem;
    border-left: 2px solid var(--color-primary);
    padding-left: 0.75rem;
    transition: color 0.2s ease;
  }

  .ex-title:hover {
    color: var(--color-primary);
  }

  .ex-meta {
    font-size: 11px;
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-weight: 300;
    line-height: 1.8;
    letter-spacing: 0.05em;
    padding-left: 0.75rem;
    border-left: 2px solid var(--color-primary-soft);
  }

  .ex-link {
    margin-top: 0.6rem;
    font-size: 11px;
    color: #fff;
    background: var(--color-primary);
    font-family: var(--font-sans);
    font-weight: 300;
    letter-spacing: 0.15em;
    display: inline-block;
    padding: 0.4rem 1rem;
    transition: opacity 0.2s ease;
  }

  .ex-link:hover {
    opacity: 0.85;
  }

  .hero-right {
    overflow: hidden;
    background: var(--color-cream);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1rem;
  }

  .placeholder-frame {
    width: 75%;
    height: 240px;
    border: 1px solid var(--color-cream-border);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .placeholder-works {
    display: flex;
    gap: 8px;
    align-items: flex-end;
  }

  .p-scroll {
    background: var(--color-cream-deep);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .p-scroll-text {
    font-size: 18px;
    font-weight: 300;
    color: #6a6058;
    writing-mode: vertical-rl;
    letter-spacing: 0.1em;
    font-family: var(--font-serif);
  }

  .placeholder-floor {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 28%;
    background: var(--color-cream-border);
    opacity: 0.35;
  }

  .placeholder-caption {
    font-size: 10px;
    color: #999;
    font-family: var(--font-sans);
    font-weight: 300;
    letter-spacing: 0.15em;
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-left {
      border-right: 0;
      border-bottom: 1px solid var(--color-line);
      padding: 2.5rem 1.2rem;
    }
    .hero-right {
      padding: 2rem 1.2rem;
    }
    .placeholder-frame {
      width: 100%;
    }
  }
</style>
